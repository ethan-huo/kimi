#!/usr/bin/env bash
set -euo pipefail

# kimi launcher（随包分发，安装后软链到 PATH）。
#
#   kimi upgrade   → 从本仓库的 GitHub Release 拉最新包，原地自替换
#   kimi <其它>    → exec bun dist/main.mjs，透传所有参数
#
# 关掉 kimi 自带的 CDN/后台更新（它面向 npm 安装，对我们这种自建包无意义，
# 且会误判 install source 为 unsupported 而反复提示）。升级走我们自己的逻辑。

REPO="ethan-huo/kimi"
TARGET="darwin-arm64"

# 解析自身所在目录（容忍 PATH 上的软链层层指向）
SRC="${BASH_SOURCE[0]}"
while [ -L "$SRC" ]; do
  link="$(readlink "$SRC")"
  case "$link" in
    /*) SRC="$link" ;;
    *)  SRC="$(dirname "$SRC")/$link" ;;
  esac
done
DIR="$(cd "$(dirname "$SRC")" && pwd)"
MAIN="$DIR/dist/main.mjs"

latest_version() {
  # 取 github.com/releases/latest 的 302 最终地址 .../tag/vX.Y.Z 解析版本。
  # 走 web 端，避开 api.github.com 未认证的 60 次/小时限流（asset 下载本身走 CDN
  # 也不受该限流影响）。
  curl -fsSLI -o /dev/null -w '%{url_effective}\n' \
    "https://github.com/$REPO/releases/latest" \
    | sed -E 's#.*/tag/v?([^/[:space:]]+).*#\1#'
}

self_upgrade() {
  local cur latest tmp url
  cur="$(cat "$DIR/VERSION" 2>/dev/null || echo 0.0.0)"
  latest="$(latest_version || true)"
  [ -n "$latest" ] || { echo "无法获取最新版本（网络？仓库无 release？）"; return 1; }

  if [ "$latest" = "$cur" ]; then
    echo "已是最新版本 ($cur)"
    return 0
  fi
  echo "升级 $cur → $latest …"

  tmp="$(mktemp -d)"
  url="https://github.com/$REPO/releases/download/v$latest/kimi-$TARGET.tar.gz"
  curl -fsSL "$url" -o "$tmp/k.tgz"

  # 有校验和就校验
  if curl -fsSL "$url.sha256" -o "$tmp/k.sha256" 2>/dev/null && [ -s "$tmp/k.sha256" ]; then
    echo "$(cat "$tmp/k.sha256")  $tmp/k.tgz" | shasum -a 256 -c - >/dev/null \
      || { echo "校验失败，已中止"; rm -rf "$tmp"; return 1; }
  fi

  mkdir -p "$tmp/new"
  tar -xzf "$tmp/k.tgz" -C "$tmp/new"

  # 备份旧目录（失败可从 .old 手动回滚）
  rm -rf "$DIR.old"
  cp -R "$DIR" "$DIR.old"

  # 关键：替换动作不能由 $DIR/kimi（正在运行的自己）执行，也不能由 $tmp 里的脚本
  # 执行——因为替换会覆盖 $DIR/kimi、清理会删掉 $tmp，任一都会抽掉正在运行脚本的
  # 文件，让 bash 后续按字节偏移读到乱码。所以拷一份新 launcher 到独立临时文件，
  # exec 它来做替换；它既不在 $DIR 也不在 $tmp 内，覆盖/清理都安全。
  applier="$(mktemp)"
  cp "$tmp/new/kimi" "$applier"
  chmod +x "$applier"
  exec bash "$applier" __apply "$DIR" "$tmp/new" "$latest" "$tmp"
}

# 内部子命令：由 self_upgrade exec 一个独立临时脚本进来，真正做替换。
if [ "${1:-}" = "__apply" ]; then
  dst="$2"; src="$3"; ver="$4"; dltmp="$5"
  rm -rf "${dst:?}/dist" "${dst:?}/node_modules"
  cp -R "$src/." "$dst/"
  chmod +x "$dst/kimi"
  rm -rf "$dltmp" # 下载临时目录（不含本脚本）
  # 注意：变量后紧跟全角标点必须用 ${} 花括号。UTF-8 locale 下 bash 会把 `（`
  # 等全角字符的字节并进变量名，导致 `$ver（` 被解析成未定义变量而报错。
  echo "✓ 已升级到 ${ver}（旧版本备份：${dst}.old）"
  exit 0
fi

if [ "${1:-}" = "upgrade" ]; then
  self_upgrade
  exit $?
fi

export KIMI_CODE_NO_AUTO_UPDATE=1
exec bun "$MAIN" "$@"
